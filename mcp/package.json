{
  "name": "specification-website-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MCP server exposing The Website Specification as queryable tools.",
  "license": "MIT",
  "scripts": {
    "build:data": "node scripts/build-data.mjs",
