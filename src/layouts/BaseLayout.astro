---
import "~/styles/global.css";
import { site } from "~/lib/site";
import { sri, pagefindImportMap } from "~/lib/integrity";
import { webmcpIntegrity } from "~/lib/webmcp";
import HeadMeta from "~/components/HeadMeta.astro";
import SiteHeader from "~/components/SiteHeader.astro";
import SiteFooter from "~/components/SiteFooter.astro";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  type?: "website" | "article";
  noindex?: boolean;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  /** When true, suppress the default page header (for landing-style pages). */
  bare?: boolean;
  /** Absolute URL of the markdown source for this page, if one exists. */
  markdownUrl?: string;
  /** Absolute URL of the JSON-LD graph endpoint for this page, if one exists. */
  jsonldUrl?: string;
  /** Root-relative path to the page's social image. Defaults to /og-default.png. */
  ogImage?: string;
}

const {
  title,
  description,
  canonical,
  type = "website",
  noindex = false,
  jsonLd,
  bare = false,
  markdownUrl,
  jsonldUrl,
  ogImage,
} = Astro.props;

const websiteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: site.name,
  url: site.url,
  description: site.description,
  inLanguage: "en",
  potentialAction: {
    "@type": "SearchAction",
    target: {
      "@type": "EntryPoint",
      urlTemplate: `${site.url}/search/?q={search_term_string}`,
    },
    "query-input": "required name=search_term_string",
  },
};

const finalJsonLd = jsonLd
  ? Array.isArray(jsonLd)
    ? [websiteJsonLd, ...jsonLd]
    : [websiteJsonLd, jsonLd]
  : websiteJsonLd;

// SRI for /webmcp.js — hashed from its generated bytes (memoised, computed once).
const webmcpSri = await webmcpIntegrity();
---

<!doctype html>
<html lang="en-GB" dir="ltr">
  <head>
    {
      /* Import map giving pagefind.js an SRI hash for its dynamic import (the
        only way to attach integrity to a dynamically imported module). Declared
        before any module script so it is in force when the search UI lazy-loads
        Pagefind. Its sha256 is CSP-allowed in _headers; regenerate both from
        src/lib/integrity.ts on a Pagefind bump. */
    }
    <script type="importmap" is:inline set:html={pagefindImportMap} />
    {
      /* Restore the stored theme override before paint to avoid FOUC, and set a
        theme-color meta that tracks the resolved theme (not just the OS), so the
        browser chrome matches a manually toggled dark mode. theme-toggle.js keeps
        it in sync at runtime. Hash-allowed by _headers CSP — DO NOT edit this
        script's bytes (or whitespace) without recomputing the sha256. Source
        pattern documented in /spec/foundations/color-scheme/. */
    }
    <script is:inline>(function(){try{var t=localStorage.getItem("theme");if(t!=="light"&&t!=="dark")t=matchMedia("(prefers-color-scheme: dark)").matches?"dark":"light";document.documentElement.setAttribute("data-theme",t);var m=document.createElement("meta");m.name="theme-color";m.id="theme-color-meta";m.content=t==="dark"?"#0e0e13":"#15803d";document.head.appendChild(m)}catch(e){}})();</script>
    {
      /* Trusted Types default policy, registered before any other script so it
        exists before Pagefind's search UI mounts. DOMPurify (self-hosted, vendored
        by scripts/generate-assets.mjs) backs it. Worked example for
        /spec/security/trusted-types/. Both are script-src 'self'. */
    }
    <script
      is:inline
      src="/vendor/purify.min.js"
      integrity={sri("/vendor/purify.min.js")}
      crossorigin="anonymous"
    ></script>
    <script
      is:inline
      src="/trusted-types-policy.js"
      integrity={sri("/trusted-types-policy.js")}
      crossorigin="anonymous"
    ></script>
    <HeadMeta
      title={title}
      description={description}
      canonical={canonical}
      type={type}
      noindex={noindex}
      jsonLd={finalJsonLd}
      markdownUrl={markdownUrl}
      jsonldUrl={jsonldUrl}
      ogImage={ogImage}
    />
    {
      import.meta.env.PROD && (
        <script
          defer
          data-domain={site.plausibleDomain}
          data-api={`${site.plausibleHost}/api/event`}
          src="/js/plausible.js"
          integrity={sri("/js/plausible.js")}
          crossorigin="anonymous"
        />
      )
    }
    <script
      type="speculationrules"
      is:inline
      set:html={JSON.stringify({
        prerender: [
          {
            source: "document",
            where: {
              and: [
                { href_matches: "/*" },
                { not: { href_matches: "/admin/*" } },
                { not: { href_matches: "/*.md" } },
                { not: { href_matches: "/*.xml" } },
                { not: { href_matches: "/*.txt" } },
                { not: { href_matches: "/*.jsonld" } },
                { not: { selector_matches: "[data-no-speculate]" } },
                { not: { selector_matches: "[rel~=external]" } },
                { not: { selector_matches: "[rel~=nofollow]" } },
              ],
            },
            eagerness: "moderate",
          },
        ],
        prefetch: [
          {
            source: "document",
            where: {
              and: [
                { href_matches: "/*" },
                { not: { href_matches: "/admin/*" } },
                { not: { selector_matches: "[data-no-speculate]" } },
                { not: { selector_matches: "[rel~=external]" } },
                { not: { selector_matches: "[rel~=nofollow]" } },
              ],
            },
            eagerness: "conservative",
          },
        ],
      })}
    />
    <slot name="head" />
  </head>
  <body class="bg-ink-50 text-ink-800">
    <a href="#main" class="skip-link">Skip to main content</a>
    {!bare && <SiteHeader />}
    <main id="main">
      <slot />
    </main>
    <SiteFooter />

    {
      /* Global ⌘K search modal — Pagefind Component UI. Inert until
        /search.js lazy-loads the component bundle on first open; the
        `:not(:defined)` rule in global.css keeps it hidden until then. */
    }
    <pagefind-config excerpt-length="30"></pagefind-config>
    <pagefind-modal id="search-modal" reset-on-close>
      <pagefind-modal-header>
        <pagefind-input placeholder="Search the spec…"></pagefind-input>
      </pagefind-modal-header>
      <pagefind-modal-body>
        <pagefind-summary></pagefind-summary>
        <pagefind-results max-results="8" max-sub-results="3"></pagefind-results>
      </pagefind-modal-body>
      <pagefind-modal-footer>
        <pagefind-keyboard-hints></pagefind-keyboard-hints>
      </pagefind-modal-footer>
    </pagefind-modal>
    <script
      src="/search.js"
      type="text/javascript"
      defer
      integrity={sri("/search.js")}
      crossorigin="anonymous"></script>
    <script
      src="/theme-toggle.js"
      type="text/javascript"
      defer
      integrity={sri("/theme-toggle.js")}
      crossorigin="anonymous"></script>
    <script
      src="/webmcp.js"
      type="text/javascript"
      defer
      integrity={webmcpSri}
      crossorigin="anonymous"></script>
  </body>
</html>
