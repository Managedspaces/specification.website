---
import BaseLayout from "~/layouts/BaseLayout.astro";
import Breadcrumbs from "~/components/Breadcrumbs.astro";
import { sri, pagefindComponentUiIntegrity } from "~/lib/integrity";
---

<BaseLayout
  title="Search"
  description="Full-text search over every spec page in the Website Specification."
  ogImage="/og/search.png"
>
  <Fragment slot="head">
    <link rel="stylesheet" href="/pagefind/pagefind-component-ui.css" />
  </Fragment>

  <div class="mx-auto max-w-3xl px-4 py-10">
    <Breadcrumbs crumbs={[{ label: "Home", href: "/" }, { label: "Search" }]} />

    <header class="mt-5 border-b border-ink-200 pb-5">
      <h1 class="text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl">
        Search
      </h1>
      <p class="mt-2 text-ink-600">
        Full-text search across every spec page. Type a topic, a header name, or
        a phrase — try
        <code class="rounded bg-ink-100 px-1.5 py-0.5 text-sm">CSP</code>,
        <code class="rounded bg-ink-100 px-1.5 py-0.5 text-sm">aria-label</code
        >, or <code class="rounded bg-ink-100 px-1.5 py-0.5 text-sm"
          >cache-control</code
        >.
      </p>
    </header>

    {
      /* Inline Pagefind Component UI search, on a dedicated `page` instance so
        it stays independent of the global ⌘K modal (which uses `default`). */
    }
    <div id="search" class="mt-8">
      <pagefind-config instance="page" excerpt-length="30"></pagefind-config>
      <pagefind-input instance="page" placeholder="Search the spec…" autofocus
      ></pagefind-input>
      <pagefind-summary instance="page" class="mt-4 block"></pagefind-summary>
      <pagefind-results
        instance="page"
        max-results="10"
        max-sub-results="3"
        class="mt-2 block"></pagefind-results>
    </div>

    <noscript>
      <p
        class="mt-6 rounded-md border border-amber-200 bg-amber-50 p-4 text-sm text-amber-900"
      >
        Search requires JavaScript. With JS off, browse <a
          class="underline"
          href="/spec/">all topics</a
        > or use
        <a class="underline" href="/llms-full.txt"><code>llms-full.txt</code></a
        > as a single searchable file.
      </p>
    </noscript>

    <!-- Pagefind: external scripts, no inline JS, no CSP nonces needed. -->
    <script
      src="/pagefind/pagefind-component-ui.js"
      type="module"
      is:inline
      integrity={pagefindComponentUiIntegrity}
      crossorigin="anonymous"></script>
    <script
      src="/search-page.js"
      type="text/javascript"
      defer
      integrity={sri("/search-page.js")}
      crossorigin="anonymous"></script>
  </div>
</BaseLayout>
